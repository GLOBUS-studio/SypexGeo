{
    "name": "globus-studio/sypexgeo",
    "description": "Maintained PHP 8 reader for the SypexGeo binary IP-to-geo database (Country, City, City Max).",
    "type": "library",
    "keywords": ["sypexgeo", "geoip", "ip-to-country", "ip-to-city", "geolocation", "ip"],
    "license": "MIT",
    "homepage": "https://packagist.org/packages/globus-studio/sypexgeo",
    "support": {
        "issues": "https://github.com/GLOBUS-studio/SypexGeo/issues",
        "source": "https://github.com/GLOBUS-studio/SypexGeo"
    },
    "authors": [
        {
            "name": "GLOBUS.studio",
            "homepage": "https://globus.studio"
        },
        {
            "name": "Yevhen Leonidov"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "GlobusStudio\\SypexGeo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GlobusStudio\\SypexGeo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "fetch-db": "@php tests/fetch-db.php"
    },
    "config": {
        "sort-packages": true
    }
}
